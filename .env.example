# TMK Fitness — environment template. Copy to .env and fill in.

# Supabase project (Project Settings -> API). The publishable/anon key is safe
# to expose in a client build — Row Level Security protects the data.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Demo auth bypass. Kept for reference only. With Supabase Auth wired in,
# leave this "false"; the login screen uses real email/password sign-in.
VITE_DEMO_AUTH=false
